# ============================================================
# Sync Agent — variáveis de ambiente (copie para .env e preencha)
# ============================================================

# --- Oracle (WinThor) — mesma conexão do app Streamlit ---
ORACLE_HOST=192.168.1.10
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=WINT
ORACLE_USER=CONSULTA
ORACLE_PASSWORD=sua_senha_aqui
# Windows: caminho do Instant Client (ex.: C:\oracle\instantclient_19_24)
# Docker:  /opt/oracle/instantclient
# Deixe vazio para usar o cliente do PATH do sistema.
ORACLE_CLIENT_DIR=

# --- Supabase Postgres ---
# Use a "Session pooler" (porta 5432, IPv4) — compativel com a rede on-premise
# e com cargas via COPY. Em Project Settings > Database > Connection string.
# postgresql://postgres.<ref>:<senha>@aws-0-<regiao>.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=

# --- Sincronização ---
# Token exigido no header x-sync-token do endpoint POST /sync (Fase 5).
SYNC_TOKEN=troque_este_token
# Janela padrão (dias para trás) quando /sync é chamado sem datas.
SYNC_DEFAULT_DAYS=30
